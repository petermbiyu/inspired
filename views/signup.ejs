<!doctype html>
<html lang="en">
  <!-- header  -->
  <%-include ("./partials/header.ejs")%>
  <!-- end header -->
  <body
    class="bg-linear-to-r from-cyan-900 to-cyan-600 md:via-cyan-600 md:to-cyan-500"
  >
    <div>
      <!-- navbar -->
      <%-include ("./partials/navbar.ejs")%>
      <!-- end navbar -->
      <div class="text-white py-3">
        <h2 class="text-2xl md:text-4xl lg:text-5xl font-bold my-8 text-center">
          Signup
        </h2>
      </div>
    </div>

    <section class="h-full px-8 py-4 bg-blue-50">
      <div>
        <form
          method="post"
          id="signup"
          class="border border-indigo-300 border-1 w-full max-w-[50rem] mx-auto my-8 p-12 rounded-[5px] bg-white"
        >
          <div class="flex align-center flex-col md:flex-row gap-4">
            <div class="w-full">
              <label for="first-name" class="text-[1.2rem]"
                >First Name <span class="text-red-500">*</span></label
              ><br />
              <input
                type="text"
                name="first-name"
                id="first-name"
                class="w-full border-2 border-indigo-100 p-[8px] text-[1.1rem] focus:outline-none rounded-[5px] bg-indigo-50"
              />
            </div>
            <div class="w-full">
              <label for="last-name" class="text-[1.2rem]"
                >Last Name <span class="text-red-500">*</span></label
              ><br />
              <input
                type="text"
                name="last-name"
                id="last-name"
                class="w-full border-2 border-indigo-100 p-[8px] text-[1.1rem] focus:outline-none rounded-[5px] bg-indigo-50"
              />
            </div>
          </div>
          <div class="w-full mt-4">
            <label for="email" class="text-[1.2rem]"
              >Email <span class="text-red-500">*</span></label
            >
            <input
              type="email"
              name="email"
              id="email"
              class="w-full border-2 border-indigo-100 p-[8px] text-[1.1rem] focus:outline-none rounded-[5px] bg-indigo-50"
            />
          </div>
          <div class="w-full mt-4">
            <label for="email" class="text-[1.2rem]"
              >Role <span class="text-red-500">*</span></label
            >
            <select
              name="role"
              id="role"
              class="w-full border-2 border-indigo-100 p-3 text-[1.1rem] focus:outline-none rounded-[5px] bg-indigo-50"
            >
              <option selected disabled hidden>Select Role</option>
              <option value="tutor">Tutor</option>
              <option value="student">Student</option>
            </select>
          </div>
          <div class="w-full mt-4 relative">
            <label for="password" class="text-[1.2rem]"
              >Password <span class="text-red-500">*</span></label
            >
            <input
              type="password"
              name="password"
              id="signup-password"
              class="w-full border-2 border-indigo-100 p-[8px] text-[1.1rem] focus:outline-none rounded-[5px] bg-indigo-50"
            />
            <span
              id="pass-sign-toggle"
              class="absolute right-[10px] bottom-[10px] cursor-pointer"
              ><i class="fa-solid fa-eye"></i
            ></span>
          </div>
          <div class="w-full mt-4 relative">
            <label for="confirm-password" class="text-[1.2rem]"
              >Confirm Password <span class="text-red-500">*</span></label
            >
            <input
              type="password"
              name="confirm-password"
              id="confirm-password"
              class="w-full border-2 border-indigo-100 p-[8px] text-[1.1rem] focus:outline-none rounded-[5px] bg-indigo-50"
            />
            <span
              id="confirm-pass-sign-toggle"
              class="absolute right-[10px] bottom-[10px] cursor-pointer"
              ><i class="fa-solid fa-eye"></i
            ></span>
          </div>
          <div class="w-full mt-8">
            <input
              type="submit"
              name="submit"
              id="submit"
              value="Signup"
              class="w-full border-2 border-indigo-100 p-[8px] text-[1.1rem] transition-all duration-300 hover:bg-indigo-100 focus:outline-none rounded-[5px] bg-indigo-50 cursor-pointer"
            />
          </div>
          <div class="flex flex-col md:flex-row mt-4">
            <div class="w-full md:w-[50%] text-[1.2rem]">
              <span
                >Have an account?
                <a href="/login" class="text-blue-700">Login</a></span
              >
            </div>
          </div>
          <div>
            <p
              id="message"
              class="px-2 py-3 absolute w-70 top-2 right-2 hidden font-semibold border-b-2 border-cyan-100 text-cyan-700 bg-cyan-50 text-center"
            ></p>
          </div>
        </form>
      </div>
    </section>

    <!-- footer -->
    <%- include ("./partials/footer.ejs")%>
    <!-- end footer -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>
    <script src="/js/script.js"></script>
    <script src="/js/signup.js"></script>
    <script src="/js/main.js"></script>
  </body>
</html>
