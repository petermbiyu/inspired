<!doctype html>
<html lang="en">
  <!-- header  -->
  <%-include ("../partials/header.ejs")%>
  <!-- end header -->
  <body
    class="bg-linear-to-r h-screen from-cyan-900 to-cyan-600 md:via-cyan-600 md:to-cyan-500"
  >
    <div>
      <!-- navbar -->
      <%-include ("../partials/navbar.ejs")%>
      <!-- end navbar -->
      <div class="text-white py-3">
        <h2 class="text-2xl md:text-4xl lg:text-5xl font-bold text-center">
          Courses
        </h2>
      </div>
    </div>

    <section class="bg-blue-50">
      <div class="md:grid md:grid-cols-[20%_80%]">
        <!-- side nave -->
        <%- include("../partials/tutorSideNav.ejs")%>
        <div
          class="flex min-h-[calc(100vh-390px)] flex-col md:flex-row justify-center items-center md:gap-6"
        >
          <div
            class="max-w-80 p-4 my-8 bg-slate-50 rounded-[5px] shadow-[0px_6px_15px_0px_rgba(0,0,0,0.25)] shadow-gray-500/50"
          >
            <h2 class="text-2xl font-semibold text-center">Mathematics</h2>
            <div class="my-2 text-[1rem]">
              <div class="italic">Level: Grade 10</div>
              <div class="italic">Strand: Indices and logarithms</div>
              <div class="italic">Substrand: Indices</div>
              <div class="italic">Date: 11-03-2026</div>
            </div>

            <div class="w-full flex items-center justify-center">
              <a
                href="/learning"
                class="inline-flex items-center justify-center w-[50px] h-[50px] rounded-full text-white text-center cursor-pointer bg-slate-500 hover:bg-slate-700 transition-all duration-300 ease mx-auto my-2"
                ><i class="fa-solid fa-arrow-up-right-from-square"></i
              ></a>
            </div>
          </div>
          <div
            class="max-w-80 p-4 my-8 bg-slate-50 rounded-[5px] shadow-[0px_6px_15px_0px_rgba(0,0,0,0.25)] shadow-gray-500/50"
          >
            <h2 class="text-2xl font-semibold text-center">Computer</h2>
            <div class="my-2 text-[1rem]">
              <div class="italic">Level: Form 3</div>
              <div class="italic">Strand: Data representaion</div>
              <div class="italic">Substrand: Number conversions</div>
              <div class="italic">Date: 11-03-2026</div>
            </div>

            <div class="w-full flex items-center justify-center">
              <a
                href="/learning"
                class="inline-flex items-center justify-center w-[50px] h-[50px] rounded-full text-white text-center cursor-pointer bg-slate-500 hover:bg-slate-700 transition-all duration-300 ease mx-auto my-2"
                ><i class="fa-solid fa-arrow-up-right-from-square"></i
              ></a>
            </div>
          </div>
          <div
            class="max-w-80 p-4 my-8 bg-slate-50 rounded-[5px] shadow-[0px_6px_15px_0px_rgba(0,0,0,0.25)] shadow-gray-500/50"
          >
            <h2 class="text-2xl font-semibold text-center">Mathematics</h2>
            <div class="my-2 text-[1rem]">
              <div class="italic">Level: Grade 10</div>
              <div class="italic">Strand: Indices and logarithms</div>
              <div class="italic">Substrand: Indices</div>
              <div class="italic">Date: 11-03-2026</div>
            </div>

            <div class="w-full flex items-center justify-center">
              <a
                href="/learning"
                class="inline-flex items-center justify-center w-[50px] h-[50px] rounded-full text-white text-center cursor-pointer bg-slate-500 hover:bg-slate-700 transition-all duration-300 ease mx-auto my-2"
                ><i class="fa-solid fa-arrow-up-right-from-square"></i
              ></a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- footer -->
    <%- include ("../partials/footer.ejs")%>
    <!-- end footer -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>
    <script src="./script.js"></script>
  </body>
</html>
